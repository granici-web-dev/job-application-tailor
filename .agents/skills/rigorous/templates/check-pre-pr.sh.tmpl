#!/usr/bin/env bash
# Local pre-PR gate — fast pre-flight before `gh pr create`. Generated by
# `{{command_prefix}}rigorous from-trd`. The authoritative, unbypassable gate is the
# GitHub Action (.github/workflows/pr-gate.yml); this mirrors its file-based checks.
# Scope = changes since the branch left {{pr_gate.main_branch}}. Canon-only diffs are exempt.
set -euo pipefail

base="$(git merge-base HEAD {{pr_gate.main_branch}} 2>/dev/null || echo HEAD)"
changed="$(git diff --name-only "$base"...HEAD; git diff --name-only)"

# Exempt canon-only changes (tooling / docs / CI / agent config).
if [ -n "$changed" ] && ! echo "$changed" | grep -qvE '^(tools|docs|\.github|\.claude)/'; then
  echo "pre-pr: canon-only diff — gate skipped."
  exit 0
fi

fail=0

if ! node tools/scripts/refresh-docs-status.mjs --check; then
  echo "pre-pr: docs stale. Run 'pnpm docs:refresh' and commit." >&2
  fail=1
fi

if ! node tools/scripts/check-pr-gate.mjs; then
  fail=1
fi

if [ ! -f ".rigorous/.critique-ran" ]; then
  echo "pre-pr: run '{{command_prefix}}rigorous critique' on the diff before opening a PR." >&2
  fail=1
fi

if [ "$fail" -eq 0 ]; then
  echo "pre-pr: ok."
else
  echo "pre-pr: blocked. Fix the above before opening the PR." >&2
  exit 1
fi
