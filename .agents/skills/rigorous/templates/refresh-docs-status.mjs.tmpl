#!/usr/bin/env node
/**
 * Meta-docs generator for the from-trd canon. Single source of truth for project
 * state: reads the binding spec, the per-requirement shapes, and live GitHub PR
 * state, then regenerates the status / shapes-index / roadmap docs.
 *
 * Generated by `{{command_prefix}}rigorous from-trd` (Phase 6 / greenfield G5).
 * Concretized from templates/refresh-docs-status.mjs.tmpl against .rigorous/trd-config.yml.
 *
 *   node tools/scripts/refresh-docs-status.mjs            # rewrite the outputs
 *   node tools/scripts/refresh-docs-status.mjs --check    # exit 1 if any output is stale or hand-edited
 *   node tools/scripts/refresh-docs-status.mjs --force    # rewrite even hand-edited outputs
 *
 * Each output carries a `sha1:<body>` header so a manual edit is detected on the
 * next run (the header no longer matches the body) and is not silently clobbered.
 */
import { readFileSync, writeFileSync, existsSync, readdirSync } from "node:fs";
import { createHash } from "node:crypto";
import { execFileSync } from "node:child_process";
import { join, basename } from "node:path";

const SPEC = "{{trd_path}}";
const UC_RE = new RegExp(String.raw`{{uc_header_regex}}`, "gm");
const SHAPE_DIR = "{{shape_dir}}";
const SHAPE_GLOB = "{{shape_glob}}"; // e.g. shape-uc-*.md
const INFORMATIONAL = "{{informational_marker}}";
const OUT = {
  status: "{{out_status}}",
  shapesIndex: "{{out_shapes_index}}",
  roadmap: "{{out_roadmap}}",
};

const HEADER_RE = /^<!-- generated by refresh-docs-status\.mjs — sha1:([0-9a-f]+) — do not edit by hand -->\n/;
const sha1 = (s) => createHash("sha1").update(s).digest("hex");
const header = (body) => `<!-- generated by refresh-docs-status.mjs — sha1:${sha1(body)} — do not edit by hand -->\n${body}`;

function splitHeader(text) {
  const m = text.match(HEADER_RE);
  if (!m) return { declared: null, body: text };
  return { declared: m[1], body: text.slice(m[0].length) };
}

/** Requirements from the spec, in document order. */
function parseSpec() {
  if (!existsSync(SPEC)) {
    throw new Error(`Binding spec not found at ${SPEC}. Check trd_path in .rigorous/trd-config.yml.`);
  }
  const text = readFileSync(SPEC, "utf8");
  const reqs = [];
  for (const m of text.matchAll(UC_RE)) {
    const id = m[1];
    const title = (m[2] ?? "").trim();
    const start = m.index + m[0].length;
    reqs.push({ id, title, start });
  }
  // Each requirement's body runs to the next requirement header; flag informational ones.
  for (let i = 0; i < reqs.length; i++) {
    const end = i + 1 < reqs.length ? reqs[i + 1].start : text.length;
    const body = text.slice(reqs[i].start, end);
    reqs[i].informational = INFORMATIONAL.length > 0 && body.includes(INFORMATIONAL);
    delete reqs[i].start;
  }
  return reqs;
}

/** Map requirement id → shape file path, by reading each shape's H1. */
function discoverShapes() {
  if (!existsSync(SHAPE_DIR)) return new Map();
  const re = new RegExp("^" + SHAPE_GLOB.replace(/[.]/g, "\\.").replace(/\*/g, ".*") + "$");
  const map = new Map();
  for (const f of readdirSync(SHAPE_DIR)) {
    if (!re.test(f)) continue;
    const first = readFileSync(join(SHAPE_DIR, f), "utf8").split("\n", 1)[0];
    const h1 = first.match(/^#\s+(\S+)\s+—/);
    if (h1) map.set(h1[1], join(SHAPE_DIR, basename(f)));
  }
  return map;
}

/** Live PR state from GitHub, keyed by requirement id found in title or branch. */
function discoverPrs(ids) {
  let prs = [];
  try {
    const raw = execFileSync(
      "gh",
      ["pr", "list", "--state", "all", "--json", "number,title,state,headRefName"],
      { encoding: "utf8", stdio: ["ignore", "pipe", "ignore"] },
    );
    prs = JSON.parse(raw);
  } catch {
    return new Map(); // gh missing, unauthenticated, or not a GitHub repo — degrade to no PR data.
  }
  const map = new Map();
  for (const id of ids) {
    const hit = prs.find((p) => p.title.includes(id) || p.headRefName.includes(id));
    if (hit) map.set(id, hit);
  }
  return map;
}

function statusOf(req, hasShape, pr) {
  if (req.informational) return "ℹ external";
  if (pr && pr.state === "MERGED") return "✅ done";
  if (pr && pr.state === "OPEN") return "🔵 in PR";
  if (hasShape) return "📝 shaped";
  return "⬜ todo";
}

function renderStatus(rows) {
  const lines = rows.map(
    (r) => `| ${r.id} | ${r.title} | ${r.shape ? "yes" : "—"} | ${r.pr ? `#${r.pr.number}` : "—"} | ${r.status} |`,
  );
  return [
    `# Project status`,
    ``,
    `Generated from \`${SPEC}\`. Do not edit by hand — run \`pnpm docs:refresh\`.`,
    ``,
    `| Req | Title | Shape | PR | Status |`,
    `|---|---|---|---|---|`,
    ...lines,
    ``,
  ].join("\n");
}

function renderShapesIndex(rows) {
  const lines = rows
    .filter((r) => r.shape)
    .map((r) => `- [\`${r.id}\`](${r.shape}) — ${r.title}`);
  const missing = rows.filter((r) => !r.shape && !r.informational).map((r) => `- ${r.id} — ${r.title}`);
  return [
    `# Shapes index`,
    ``,
    `Per-requirement planning shapes. Generated — run \`pnpm docs:refresh\`.`,
    ``,
    `## Shaped`,
    ...(lines.length ? lines : [`- none yet`]),
    ``,
    `## Not yet shaped`,
    ...(missing.length ? missing : [`- none`]),
    ``,
  ].join("\n");
}

function renderRoadmap(rows) {
  const buckets = [
    ["✅ done", "Done"],
    ["🔵 in PR", "In PR"],
    ["📝 shaped", "Shaped, not started"],
    ["⬜ todo", "Backlog"],
    ["ℹ external", "Informational / out of scope"],
  ];
  const out = [`# Roadmap`, ``, `Generated — run \`pnpm docs:refresh\`.`, ``];
  for (const [key, label] of buckets) {
    const items = rows.filter((r) => r.status === key);
    out.push(`## ${label} (${items.length})`);
    out.push(...(items.length ? items.map((r) => `- ${r.id} — ${r.title}`) : [`- none`]), ``);
  }
  return out.join("\n");
}

function reconcile(path, nextBody, { check, force }) {
  const exists = existsSync(path);
  const current = exists ? readFileSync(path, "utf8") : null;
  const { declared, body } = current ? splitHeader(current) : { declared: null, body: null };
  const handEdited = exists && declared !== null && declared !== sha1(body);
  const stale = !exists || body !== nextBody;

  if (check) {
    if (handEdited) return { ok: false, reason: "hand-edited" };
    if (stale) return { ok: false, reason: "stale" };
    return { ok: true };
  }
  if (handEdited && !force) {
    return { ok: false, reason: "hand-edited (skipped — pass --force to overwrite)" };
  }
  if (stale || force) writeFileSync(path, header(nextBody));
  return { ok: true, wrote: stale || force };
}

function main() {
  const check = process.argv.includes("--check");
  const force = process.argv.includes("--force");

  const reqs = parseSpec();
  const shapes = discoverShapes();
  const prs = discoverPrs(reqs.map((r) => r.id));
  const rows = reqs.map((r) => {
    const shape = shapes.get(r.id) ?? null;
    const pr = prs.get(r.id) ?? null;
    return { ...r, shape, pr, status: statusOf(r, !!shape, pr) };
  });

  const targets = [
    [OUT.status, renderStatus(rows)],
    [OUT.shapesIndex, renderShapesIndex(rows)],
    [OUT.roadmap, renderRoadmap(rows)],
  ];

  let failed = false;
  for (const [path, body] of targets) {
    const res = reconcile(path, body, { check, force });
    if (!res.ok) {
      failed = true;
      console.error(`${check ? "stale" : "blocked"}: ${path} (${res.reason})`);
    } else if (res.wrote) {
      console.log(`wrote ${path}`);
    }
  }

  if (check && failed) {
    console.error(`\nDocs are out of date. Run \`pnpm docs:refresh\` and commit the result.`);
    process.exit(1);
  }
  if (!check) console.log(`${reqs.length} requirements, ${shapes.size} shaped.`);
}

main();
