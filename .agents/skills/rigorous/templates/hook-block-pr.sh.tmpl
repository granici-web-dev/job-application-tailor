#!/usr/bin/env bash
# Claude Code PreToolUse hook. Blocks a `gh pr create` Bash call unless the local
# pre-PR gate passes. Reads the tool-call JSON on stdin; ignores every other command.
# Exit 2 tells Claude Code to block the tool and feed stderr back to the model.
# Generated by `{{command_prefix}}rigorous from-trd`.
set -euo pipefail

input="$(cat)"
cmd="$(printf '%s' "$input" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{process.stdout.write(JSON.parse(s).tool_input?.command||"")}catch{process.stdout.write("")}})')"

case "$cmd" in
  *"gh pr create"*)
    if ! bash tools/scripts/check-pre-pr.sh >&2; then
      echo "Blocked: pre-PR gate failed (critique / e2e-no-mocks / docs). Fix the above, then retry." >&2
      exit 2
    fi
    ;;
esac
exit 0
