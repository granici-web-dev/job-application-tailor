name: PR gate

# Server-side enforcement — cannot be bypassed. Generated by `{{command_prefix}}rigorous from-trd`.
# Blocks a PR unless:
#  - `rigorous critique` is ticked in the description,
#  - app changes ship an e2e test of the delivered functionality with no mocks,
#  - frontend changes include a screenshot in the description,
#  - the generated docs canon is up to date.
on:
  pull_request:
    types: [opened, edited, synchronize, reopened]

jobs:
  gate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Compute changed files
        run: |
          git diff --name-only \
            "${{ github.event.pull_request.base.sha }}" \
            "${{ github.event.pull_request.head.sha }}" > /tmp/changed.txt
          echo "changed:"; cat /tmp/changed.txt

      - name: Docs canon up to date
        run: node tools/scripts/refresh-docs-status.mjs --check

      - name: PR gate (critique + e2e no-mocks + screenshot)
        env:
          PR_BODY: ${{ github.event.pull_request.body }}
        run: node tools/scripts/check-pr-gate.mjs --changed-file /tmp/changed.txt
