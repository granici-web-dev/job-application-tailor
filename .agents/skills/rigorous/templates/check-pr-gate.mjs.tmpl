#!/usr/bin/env node
/**
 * PR gate. Enforces the rules a PR must satisfy before it opens. Shared by the
 * GitHub Action (.github/workflows/pr-gate.yml) and the local pre-PR hook
 * (tools/scripts/check-pre-pr.sh). Generated by `{{command_prefix}}rigorous from-trd`.
 *
 *   node tools/scripts/check-pr-gate.mjs --changed-file <path>   # one changed path per line
 *   node tools/scripts/check-pr-gate.mjs                         # derive changed files from git vs {{pr_gate.main_branch}}
 * Reads the PR body from $PR_BODY or --body-file <path>. With no body (local,
 * pre-creation) the body-dependent rules are reported as notes, not failures.
 *
 * Rules:
 *   1. Every PR: the description ticks the `{{command_prefix}}rigorous critique` checkbox.   [body]
 *   2. App functionality delivered ({{pr_gate.app_src_prefix}}** source changed) requires:
 *        a. the `e2e (no mocks)` checkbox ticked,                              [body]
 *        b. at least one e2e test changed in the branch,                       [files]
 *        c. no mock APIs in the changed e2e tests.                             [files]
 *   3. Frontend touched ({{pr_gate.frontend_prefix}}** changed) requires a screenshot in the body. [body]
 */
import { readFileSync, existsSync } from "node:fs";
import { execFileSync } from "node:child_process";

const APP_SRC_PREFIX = "{{pr_gate.app_src_prefix}}";
const FRONTEND_PREFIX = "{{pr_gate.frontend_prefix}}";
const MAIN_BRANCH = "{{pr_gate.main_branch}}";

const args = process.argv.slice(2);
const opt = (name) => {
  const i = args.indexOf(name);
  return i >= 0 ? args[i + 1] : undefined;
};

function changedFiles() {
  const f = opt("--changed-file");
  if (f && existsSync(f)) {
    return readFileSync(f, "utf8").split("\n").map((s) => s.trim()).filter(Boolean);
  }
  try {
    const base = execFileSync("git", ["merge-base", "HEAD", MAIN_BRANCH], { encoding: "utf8" }).trim();
    const committed = execFileSync("git", ["diff", "--name-only", `${base}...HEAD`], { encoding: "utf8" });
    const working = execFileSync("git", ["diff", "--name-only"], { encoding: "utf8" });
    return [...new Set((committed + working).split("\n").map((s) => s.trim()).filter(Boolean))];
  } catch {
    return [];
  }
}

function prBody() {
  const f = opt("--body-file");
  if (f && existsSync(f)) return readFileSync(f, "utf8");
  return process.env.PR_BODY ?? null;
}

const isE2e = (p) => /(^|\/)e2e\//.test(p) || /\.e2e\.[tj]sx?$/.test(p) || /\.e2e\.mjs$/.test(p);
const isTest = (p) => isE2e(p) || /\.(test|spec)\.[tj]sx?$/.test(p);
const isAppSrc = (p) =>
  p.startsWith(APP_SRC_PREFIX) && !isTest(p) && !p.endsWith(".gitkeep") && !p.endsWith(".md");
const isFrontend = (p) => p.startsWith(FRONTEND_PREFIX);

const MOCK_RE =
  /\b(vi|jest)\.mock\b|\bsinon\b|\brequire\(['"]nock|from ['"]nock|\bnock\(|\bcreateMock\b|\bmockDeep\b|@golevelup\/ts-jest|jest-mock-extended/;

const SCREENSHOT_RE =
  /!\[[^\]]*\]\([^)]+\)|<img\s|https?:\/\/\S+\.(png|jpe?g|gif|webp)|user-images\.githubusercontent\.com|github\.com\/user-attachments/i;

function checkboxTicked(body, keyword) {
  const re = new RegExp(`^\\s*-\\s*\\[[xX]\\].*${keyword}`, "im");
  return re.test(body);
}

function main() {
  const files = changedFiles();
  const body = prBody();
  const failures = [];
  const notes = [];

  const frontendChanged = files.some(isFrontend);
  const appSrcChanged = files.some(isAppSrc);
  const e2eChanged = files.filter(isE2e);

  if (body == null) notes.push("critique checkbox: not checkable without PR body (CI enforces it).");
  else if (!checkboxTicked(body, "critique"))
    failures.push("PR description must tick the `rigorous critique` checkbox.");

  if (appSrcChanged) {
    if (body == null) notes.push("e2e checkbox: not checkable without PR body (CI enforces it).");
    else if (!checkboxTicked(body, "e2e"))
      failures.push("App code changed: PR description must tick the `e2e (no mocks)` checkbox.");

    if (e2eChanged.length === 0)
      failures.push("App code changed but no e2e test was added or updated in this branch.");

    for (const f of e2eChanged) {
      if (existsSync(f) && MOCK_RE.test(readFileSync(f, "utf8")))
        failures.push(`e2e test uses mocks (forbidden): ${f}. Use real services (test containers).`);
    }
  }

  if (frontendChanged) {
    if (body == null) notes.push("screenshot: not checkable without PR body (CI enforces it).");
    else if (!SCREENSHOT_RE.test(body))
      failures.push("Frontend changed: PR description must include a screenshot.");
  }

  for (const n of notes) console.error(`note: ${n}`);
  if (failures.length) {
    console.error("\nPR gate failed:");
    for (const f of failures) console.error(`  ✗ ${f}`);
    process.exit(1);
  }
  console.log("PR gate: ok.");
}

main();
